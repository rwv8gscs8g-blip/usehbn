{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HBN Intent",
  "type": "object",
  "required": [
    "objective",
    "constraints",
    "risks",
    "validation_requirements"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}

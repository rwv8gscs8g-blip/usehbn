{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HBN Guardian Report",
  "type": "object",
  "required": [
    "status",
    "warnings",
    "log_path"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "clear",
        "warn"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "severity",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "log_path": {
      "type": "string"
    }
  }
}

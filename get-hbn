#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
VENV_DIR="$SCRIPT_DIR/.venv"
PYTHON_BIN="$VENV_DIR/bin/python"
HBN_BIN="$VENV_DIR/bin/hbn"
USEHBN_BIN="$VENV_DIR/bin/usehbn"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to bootstrap HBN locally." >&2
  exit 1
fi

if [ ! -d "$VENV_DIR" ]; then
  python3 -m venv "$VENV_DIR"
fi

cat > "$HBN_BIN" <<EOF
#!/usr/bin/env sh
PYTHONPATH="$SCRIPT_DIR/src\${PYTHONPATH:+:\$PYTHONPATH}" exec "$PYTHON_BIN" -m usehbn "\$@"
EOF

cat > "$USEHBN_BIN" <<EOF
#!/usr/bin/env sh
exec "$HBN_BIN" "\$@"
EOF

chmod +x "$HBN_BIN" "$USEHBN_BIN"

echo "HBN bootstrap complete."
echo "Try: $HBN_BIN version"
